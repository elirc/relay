# Copy to .env and adjust as needed.

# Postgres — runs, steps, events, connections (see packages/db/docker-compose.yml)
DATABASE_URL="postgresql://relay:relay@localhost:5432/relay?schema=public"

# Redis — the engine's job queue (BullMQ). Holds WORK, not truth.
REDIS_URL="redis://localhost:6379"

# API
API_PORT=3001

# Web (Next.js) — where the browser reaches the API
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Secrets (S2+): master key-encryption-key for envelope-encrypting connection tokens.
# EXACTLY 32 bytes, base64-encoded. Generate a real one per environment; NEVER commit a prod key.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
RELAY_MASTER_KEK="cmVsYXktZGV2LW1hc3Rlci1rZXktMDEyMzQ1Njc4OWE="
