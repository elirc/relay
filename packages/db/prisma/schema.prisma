// Prisma schema for Relay.
// S01: the run-recording core — Relay (a workflow), Run, StepRun, and the append-only RunEvent log.
// Deliberately minimal. Connections + orgs arrive S02; immutable relay Versions + checkpoints S05/S07.
//
// ADR-0002: run state lives HERE (Postgres), not in Redis. Runs are business records — queryable,
// durable, auditable. Redis holds *work* (the job queue); Postgres holds *truth*. If Redis vanished
// mid-run, everything in this schema must survive.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Orgs, identity, connections (S02) ──────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  // The org's DEK, wrapped by the master KEK (envelope encryption, ADR-0004). Generated lazily the
  // first time the org stores a secret. NULL until then — no org pays for a key it hasn't used.
  wrappedDek  String?
  createdAt   DateTime      @default(now())
  memberships Membership[]
  connections Connection[]
  relays      Relay[]
  codeSteps   CodeStep[]
}

// A user-authored JavaScript code step (S09), versioned and pinned like a relay version. The source is
// stored; it runs in the sandbox with a controlled surface, resource limits, and allowlisted egress.
model CodeStep {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  source    String // the user's JavaScript
  version   Int      @default(1)
  createdAt DateTime @default(now())

  @@index([orgId])
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  createdAt   DateTime     @default(now())
  memberships Membership[]
  sessions    Session[]
}

model Membership {
  id     String @id @default(cuid())
  userId String
  orgId  String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role   String       @default("ADMIN") // ADMIN | MEMBER — compressed for S02

  @@unique([userId, orgId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // We store only a HASH of the session token — a DB leak can't be replayed as a live session.
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Connection {
  id                String   @id @default(cuid())
  orgId             String
  org               Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vendor            String // "mailpost" | "sheetlite" | "chatbox"
  externalAccountId String?
  // Health is STORED, not computed at run time (S02 lesson): a connection that died Tuesday must be
  // visible as unhealthy now, not discovered when a run fails at 3am.
  status            String   @default("healthy") // healthy | unhealthy
  scopes            String[]
  // Tokens are envelope-encrypted with the org DEK — never at rest in plaintext.
  accessTokenEnc    String?
  refreshTokenEnc   String?
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([orgId])
}

model Relay {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime        @default(now())
  runs      Run[]
  versions  RelayVersion[]
  bindings  TriggerBinding[]

  @@index([orgId])
}

// How a relay gets triggered (S06): one of three species. Created at publish; a webhook binding also
// registers a subscription on the vendor (vendorSubId) that a reconcile sweep keeps honest.
model TriggerBinding {
  id            String   @id @default(cuid())
  relayId       String
  relay         Relay    @relation(fields: [relayId], references: [id], onDelete: Cascade)
  kind          String // polling | webhook | schedule
  connector     String
  triggerKey    String
  connectionId  String?
  cursor        String? // polling: newest item id seen
  webhookSecret String? // shared secret for verifying inbound signatures
  vendorSubId   String? // managed webhook subscription id at the vendor
  scheduleTier  String? // free | pro | business
  misfirePolicy String?  @default("skip") // skip | runOnce
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([relayId])
}

// An immutable snapshot of a relay's graph (S04). Editing a published version doesn't mutate it —
// it creates a new draft. A Run pins the version it started on, so "what did this relay look like when
// it ran?" always has an answer. That immutability is the precondition for S07 replay.
model RelayVersion {
  id         String   @id @default(cuid())
  relayId    String
  relay      Relay    @relation(fields: [relayId], references: [id], onDelete: Cascade)
  version    Int
  definition Json // { trigger, steps } — see @relay/shared RelayDefinition
  status     String   @default("draft") // draft | published
  createdAt  DateTime @default(now())
  runs       Run[]

  @@unique([relayId, version])
}

model Run {
  id         String     @id @default(cuid())
  relayId    String
  relay      Relay      @relation(fields: [relayId], references: [id], onDelete: Cascade)
  // The pinned relay version this run executes. Nullable for the S01 hardcoded-relay runs.
  versionId  String?
  version    RelayVersion? @relation(fields: [versionId], references: [id])
  // Status is a String whose allowed values are the RunStatus union in @relay/shared — the domain
  // vocabulary lives in ONE place (shared), not duplicated as a Prisma enum that could drift.
  status     String     @default("pending")
  trigger    Json // the inbound trigger payload that started this run
  createdAt  DateTime   @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  steps      StepRun[]
  events     RunEvent[]

  @@index([relayId, createdAt])
}

// A StepRun is a durable CHECKPOINT (S07): once it commits SUCCEEDED, a resume rehydrates its output
// and never re-executes the step. `idempotencyKey` is the stable key that travels with the side effect
// so a crash between the vendor's ack and this checkpoint can't cause a duplicate.
model StepRun {
  id             String    @id @default(cuid())
  runId          String
  run            Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepId         String // the step's id within the relay
  status         String    @default("pending") // pending | running | succeeded | failed
  attempt        Int       @default(1)
  // Small outputs stay inline in `output`; large ones (> threshold) are offloaded to object storage and
  // only `outputRef` stays here (S10, flaw #2 harvest — blobs no longer bloat the OLTP runs table).
  output         Json?
  outputRef      String?
  error          String?
  idempotencyKey String?
  committedAt    DateTime? // set when the checkpoint durably commits SUCCEEDED
  createdAt      DateTime  @default(now())

  @@unique([runId, stepId])
}

model RunEvent {
  id     String   @id @default(cuid())
  runId  String
  run    Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  // `seq` is monotonic within a run — the append-only ordering key, independent of wall-clock. The
  // unique constraint makes the log tamper-evident: you cannot silently insert or reorder an event.
  seq    Int
  type   String // RunEventType from @relay/shared
  stepId String?
  data   Json?
  at     DateTime @default(now())

  @@unique([runId, seq])
  @@index([runId, seq])
}
