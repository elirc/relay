{
  "name": "@relay/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/worker.ts",
    "build": "tsup src/worker.ts --format esm --clean --external @prisma/client --external bullmq --external ioredis --external zod",
    "start": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src"
  },
  "dependencies": {
    "@relay/db": "workspace:*",
    "@relay/shared": "workspace:*",
    "bullmq": "^5.28.1",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@relay/config": "workspace:*",
    "@types/node": "^22.7.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
