{
  "name": "@relay/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean --external @prisma/client --external fastify --external bullmq --external ioredis --external zod",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@relay/db": "workspace:*",
    "@relay/secrets": "workspace:*",
    "@relay/shared": "workspace:*",
    "@relay/vendor-farm": "workspace:*",
    "bullmq": "^5.28.1",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@relay/config": "workspace:*",
    "@types/node": "^22.7.9",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
